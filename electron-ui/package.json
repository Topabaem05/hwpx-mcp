{
  "name": "hwpx-mcp-electron-ui",
  "version": "4.0.1",
  "buildVersionLabel": "4.0.1",
  "private": true,
  "description": "Electron desktop client for HWPX-MCP document workbench",
  "author": {
    "name": "HWP MCP Team",
    "email": "hwpx-mcp@users.noreply.github.com"
  },
  "homepage": "https://github.com/Topabaem05/hwpx-mcp",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start-stack": "node ./scripts/start-stack.js",
    "dev": "electron .",
    "build:backend:win": "powershell -ExecutionPolicy Bypass -File ../scripts/build-windows-backend.ps1",
    "build:codex-proxy:win": "powershell -ExecutionPolicy Bypass -File ../scripts/build-windows-codex-proxy.ps1",
    "build:win": "node ./scripts/ensure-local-model.js && node ./scripts/ensure-vcredist.js && node ./scripts/ensure-wine.js && electron-builder --win",
    "build:win:bundle": "npm run build:backend:win && npm run build:codex-proxy:win && npm run build:win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:dir": "node ./scripts/ensure-local-model.js && node ./scripts/ensure-vcredist.js && node ./scripts/ensure-wine.js && electron-builder --win --dir"
  },
  "build": {
    "appId": "io.topabaem05.hwpx-mcp",
    "productName": "HWPX MCP",
    "publish": [
      {
        "provider": "github",
        "owner": "Topabaem05",
        "repo": "hwpx-mcp",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "../dist/electron-installer"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist/hwpx-mcp-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../dist/codex-proxy",
        "to": "codex-proxy",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraFiles": [],
    "win": {
      "target": "nsis",
      "artifactName": "HWPX.MCP-${version}-win-${arch}.${ext}",
      "extraResources": [
        {
          "from": "../dist/hwpx-mcp-backend-win",
          "to": "backend-win",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "../dist/codex-proxy-win",
          "to": "codex-proxy-win",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "../dist/windows-prereqs",
          "to": "windows-prereqs",
          "filter": [
            "vc_redist.x64.exe"
          ]
        },
        {
          "from": "../dist/local-models",
          "to": "local-models",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "runAfterFinish": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "installer.nsh"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "afterPack": "./scripts/after-pack.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^26.8.0"
  },
  "engines": {
    "node": ">=18"
  }
}
